# Supabase + Prisma
# Get these from: Supabase Dashboard → Project Settings → Database
#
# DATABASE_URL: Use "Connection string" → "URI" (Transaction pooler recommended for Next.js)
#   Format: postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#   Or direct: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Optional (for Supabase client / RLS later):
#   NEXT_PUBLIC_SUPABASE_URL = https://[PROJECT-REF].supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = your-anon-key
#
# Vendors REST table (PostgREST). Snake_case Postgres example:
#   NEXT_PUBLIC_SUPABASE_VENDORS_TABLE=carry_class_vendor_data
# Legacy sheet-style name (spaces OK): "CarryClass Vendor Data" — also the code default if unset.
#
# Required when the table name does NOT contain "CarryClass" (see isCarryClassVendorShape in vendors-db):
#   NEXT_PUBLIC_SUPABASE_VENDORS_SHAPE=carryclass
# Alternative shapes: legacy | prisma | vendor
#
# Optional: server-side vendor reads bypass RLS (Dashboard → Settings → API → service_role).
# Do NOT expose this to the browser; keep it server-only (e.g. only read in vendors-db).
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Clerk — required in production (Dashboard → API Keys)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...
# Optional: customize sign-in/up URLs
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# App URL (used by Stripe Checkout redirects)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 (loaded in production only)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-T2T75KLYGL

# Stripe — booking / Checkout (test keys from Stripe Dashboard)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CLIENT_ID=ca_...  (Connect → OAuth client id, test mode for local dev)
# Add redirect URI in Stripe Dashboard → Connect → OAuth:
#   http://localhost:3001/api/stripe-connect/callback
# Must be sk_test_/sk_live_ — restricted keys (rk_) do not work for Connect OAuth.

# Google Places (Place Details API) for vendor listing Google reviews
# Server-only key. Enable Places API and keep unrestricted by client origin.
# GOOGLE_PLACES_API_KEY=AIza...

# Optional: demo vendor Connect account for prisma seed (`npm run db:seed`)
# Must be a test Connect account id (acct_...) from Stripe Dashboard → Connect
# DEMO_VENDOR_STRIPE_CONNECT_ACCOUNT_ID=acct_...
