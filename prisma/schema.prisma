// Prisma schema for CCW Directory
// Database: PostgreSQL (Supabase)
// https://supabase.com/docs/guides/database/connecting-to-postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  type           String   // "instructor" | "company"
  city           String
  county         String
  state          String
  countiesServed String[] // County slugs
  classTypes     String[] // "initial" | "renewal" | "both"
  formats        String[] // "in-person" | "online" | "hybrid"
  priceMin       Int?
  priceMax       Int?
  priceInitial   Int?
  priceRenewal   Int?
  priceAddGun    Int?
  address        String?
  discountInfo   String?
  website        String?
  phone          String?
  email          String?
  description    String?
  imageUrl       String?
  photos         String[] // Gallery URLs
  googleReviewsUrl String?
  googlePlaceId  String?
  featured       Boolean  @default(false)
  createdAt      DateTime @default(now())

  /** When true, vendor profile shows Book Now and /vendors/[slug]/book is enabled */
  acceptsBookings Boolean @default(false)
  /** Stripe Connect account id (acct_...) — required to run Checkout with application fee */
  stripeConnectAccountId String?

  classSessions ClassSession[]
  bookings      Booking[]
  reviews       VendorReview[]
  savedByUsers  SavedVendor[]

  @@index([county])
  @@index([slug])
  @@index([featured])
}

model SavedVendor {
  id        String   @id @default(cuid())
  userId    String
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, vendorId])
  @@index([userId, createdAt])
  @@index([vendorId])
}

enum VendorReviewStatus {
  PENDING
  APPROVED
}

model VendorReview {
  id         String             @id @default(cuid())
  vendorId   String
  vendor     Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  rating     Int
  authorName String
  body       String
  status     VendorReviewStatus @default(PENDING)
  createdAt  DateTime           @default(now())

  @@index([vendorId])
  @@index([vendorId, status, createdAt])
}

model ClassSession {
  id         String   @id @default(cuid())
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime?
  title      String?
  classType  String // "initial" | "renewal"
  priceCents Int // Class tuition portion (USD cents)
  capacity   Int      @default(12)
  enrolled   Int      @default(0)
  timezone   String   @default("America/Los_Angeles")
  createdAt  DateTime @default(now())

  bookings Booking[]

  @@index([vendorId, startsAt])
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum CcwTimelineProcess {
  INITIAL
  RENEWAL
  MODIFICATION
}

enum CcwTimelineStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CcwTimelineSource {
  DOCX_IMPORT
  USER_FORM
  MANUAL
}

/// Self-reported CCW application timelines (initial / renewal / modification).
/// Mirrors VendorReview moderation pattern: rows are PENDING until approved.
model CcwTimelineSubmission {
  id              String              @id @default(cuid())
  countySlug      String              // canonical slug, e.g. "los-angeles"
  process         CcwTimelineProcess
  status          CcwTimelineStatus   @default(PENDING)
  displayName     String              @default("Anonymous")
  body            String
  dateStarted     DateTime?
  dateFinished    DateTime?
  /// Required for any APPROVED row used in metrics. Computed server-side.
  durationDays    Int?
  totalCostCents  Int?
  sourceType      CcwTimelineSource   @default(USER_FORM)
  /// Stable identifier for re-import dedup (e.g. hash of original docx segment).
  sourceRef       String?             @unique
  rawText         String?
  parseConfidence Float?
  parseWarnings   String[]
  submittedAt     DateTime            @default(now())
  reviewedAt      DateTime?

  @@index([countySlug])
  @@index([countySlug, process, status])
  @@index([status, submittedAt])
}

model Booking {
  id        String @id @default(cuid())
  vendorId  String
  vendor    Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  classSessionId String
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?

  customerEmail String
  customerName  String
  clerkUserId   String?

  classAmountCents   Int
  serviceFeeCents    Int @default(700)
  totalAmountCents   Int

  status BookingStatus @default(PENDING)
  paidAt DateTime?

  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([classSessionId])
  @@index([status])
}
